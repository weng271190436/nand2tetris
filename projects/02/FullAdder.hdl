// File name: projects/2/FullAdder.hdl
/**
 * Full adder: sum = LSB of a + b + c; carry = MSB of a + b + c
 */
CHIP FullAdder {
    IN a, b, c;
    OUT sum, carry;

    PARTS:
    HalfAdder(a=a, b=b, sum=sum1, carry=carry1);
    HalfAdder(a=sum1, b=c, sum=sum, carry=carry2);
    Or(a=carry1, b=carry2, out=carry);
}
